# =============================================
# NewsMind AI - Frontend Environment Variables
# =============================================
# Copy this file as .env and fill in your values

# For LOCAL development: leave blank (Vite proxy handles /api → localhost:5000)
# For PRODUCTION (Vercel): set to your Render backend URL
# Example: VITE_API_URL=https://your-app-name.onrender.com/api/v1
VITE_API_URL=

VITE_APP_NAME=NewsMind AI
