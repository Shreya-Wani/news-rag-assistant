# =============================================
# NewsMind AI - Environment Variables
# =============================================
# Copy this file as .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/newsmind-ai

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace Configuration (Used for Embeddings)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=newsmind-ai
PINECONE_HOST=your_pinecone_host_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here

# CORS Configuration
# For LOCAL: http://localhost:5173
# For PRODUCTION: your Vercel URL (e.g. https://your-app.vercel.app)
CLIENT_URL=http://localhost:5173

# JWT Secret (for future auth)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
